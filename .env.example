# ============================================================================
# Zona Sport — variables de entorno
# Copiar a .env.local para desarrollo. En Vercel se configuran en el dashboard.
# ============================================================================

# ---------------------------------------------------------------------------
# Base de datos (Neon Postgres vía Vercel Marketplace)
# La integración inyecta automáticamente DATABASE_URL y DATABASE_URL_UNPOOLED.
# Para desarrollo local, crear una rama de Neon o usar Postgres local.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:pass@localhost:5432/zonasport?schema=public"
DATABASE_URL_UNPOOLED="postgresql://user:pass@localhost:5432/zonasport?schema=public"

# ---------------------------------------------------------------------------
# Auth.js v5 (NextAuth)
# Generar: openssl rand -base64 32   (o:  npx auth secret)
# ---------------------------------------------------------------------------
AUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-de-32-bytes-base64"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-de-32-bytes-base64"

# ---------------------------------------------------------------------------
# Vercel Blob — Storage de imágenes de producto y blog
# Crear store desde Vercel Dashboard → Storage → Blob.
# ---------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=""

# ---------------------------------------------------------------------------
# Email transaccional (Resend)
# Dominio zonasport.es verificado con DKIM/SPF/DMARC.
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM="Zona Sport <hola@zonasport.es>"
RESEND_REPLY_TO="hola@zonasport.es"
ADMIN_NOTIFICATION_EMAIL="hola@zonasport.es"

# ---------------------------------------------------------------------------
# Movalia (proveedor B2B externo)
# Rellenar cuando el cliente facilite credenciales y formato del feed.
# ---------------------------------------------------------------------------
MOVALIA_ENABLED="false"
MOVALIA_FEED_URL=""
MOVALIA_FEED_FORMAT=""     # csv | xml | json | soap
MOVALIA_AUTH_TYPE=""       # basic | bearer | apikey | none
MOVALIA_USERNAME=""
MOVALIA_PASSWORD=""
MOVALIA_API_KEY=""

# ---------------------------------------------------------------------------
# Amazon PA-API 5.0 (Associates España)
# Stub funcional hasta que el cliente facilite credenciales.
# ---------------------------------------------------------------------------
AMAZON_ENABLED="false"
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""
AMAZON_ASSOCIATE_TAG=""
AMAZON_HOST="webservices.amazon.es"
AMAZON_REGION="eu-west-1"

# ---------------------------------------------------------------------------
# Cron (Vercel Cron protege handlers con Bearer token)
# Generar: openssl rand -hex 32
# ---------------------------------------------------------------------------
CRON_SECRET="cambia-esto-por-un-token-aleatorio-largo"

# ---------------------------------------------------------------------------
# Site público (datos visibles al cliente)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Zona Sport"
NEXT_PUBLIC_WHATSAPP_NUMBER="34689110691"
NEXT_PUBLIC_CONTACT_EMAIL="hola@zonasport.es"
NEXT_PUBLIC_STORE_ADDRESS="C. Silos, 3, 06490 Puebla de la Calzada, Badajoz"
NEXT_PUBLIC_STORE_PHONE="+34 689 11 06 91"

# ---------------------------------------------------------------------------
# Verificación Search Console (opcional)
# ---------------------------------------------------------------------------
GOOGLE_SITE_VERIFICATION=""

# ---------------------------------------------------------------------------
# Seed inicial (solo para primer arranque local; cambiar en producción)
# ---------------------------------------------------------------------------
SEED_OWNER_EMAIL="admin@zonasport.es"
SEED_OWNER_PASSWORD="ChangeMe2026!"
SEED_OWNER_NAME="Administrador Zona Sport"

# ---------------------------------------------------------------------------
# Modo desarrollo
# ---------------------------------------------------------------------------
NODE_ENV="development"
