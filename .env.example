# ============================================================================
# Zona Sport â€” variables de entorno
# Copiar a .env.local para desarrollo. En Vercel se configuran en el dashboard.
# ============================================================================

# ---------------------------------------------------------------------------
# Base de datos (Neon Postgres vÃ­a Vercel Marketplace)
# La integraciÃ³n inyecta automÃ¡ticamente DATABASE_URL y DATABASE_URL_UNPOOLED.
# Para desarrollo local, crear una rama de Neon o usar Postgres local.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:pass@localhost:5432/zonasport?schema=public"
DATABASE_URL_UNPOOLED="postgresql://user:pass@localhost:5432/zonasport?schema=public"

# ---------------------------------------------------------------------------
# Auth.js v5 (NextAuth)
# Generar: openssl rand -base64 32   (o:  npx auth secret)
# ---------------------------------------------------------------------------
AUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-de-32-bytes-base64"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-de-32-bytes-base64"

# ---------------------------------------------------------------------------
# Vercel Blob â€” Storage de imÃ¡genes de producto y blog
# Crear store desde Vercel Dashboard â†’ Storage â†’ Blob.
# ---------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=""

# ---------------------------------------------------------------------------
# Email transaccional (Resend)
# Dominio zonasport.es verificado con DKIM/SPF/DMARC.
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM="Zona Sport <hola@zonasport.es>"
RESEND_REPLY_TO="hola@zonasport.es"
ADMIN_NOTIFICATION_EMAIL="hola@zonasport.es"

# ---------------------------------------------------------------------------
# Miravia (proveedor B2B externo)
# Rellenar cuando el cliente facilite credenciales y formato del feed.
# ---------------------------------------------------------------------------
MIRAVIA_ENABLED="false"
MIRAVIA_FEED_URL=""
MIRAVIA_FEED_FORMAT=""     # csv | xml | json | soap
MIRAVIA_AUTH_TYPE=""       # basic | bearer | apikey | none
MIRAVIA_USERNAME=""
MIRAVIA_PASSWORD=""
MIRAVIA_API_KEY=""

# ---------------------------------------------------------------------------
# Amazon PA-API 5.0 (Associates EspaÃ±a)
# Stub funcional hasta que el cliente facilite credenciales.
# ---------------------------------------------------------------------------
AMAZON_ENABLED="false"
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""
AMAZON_ASSOCIATE_TAG=""
AMAZON_HOST="webservices.amazon.es"
AMAZON_REGION="eu-west-1"

# ---------------------------------------------------------------------------
# Cron (Vercel Cron protege handlers con Bearer token)
# Generar: openssl rand -hex 32
# ---------------------------------------------------------------------------
CRON_SECRET="cambia-esto-por-un-token-aleatorio-largo"

# ---------------------------------------------------------------------------
# Site pÃºblico (datos visibles al cliente)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Zona Sport"
NEXT_PUBLIC_WHATSAPP_NUMBER="34689110691"
NEXT_PUBLIC_CONTACT_EMAIL="hola@zonasport.es"
NEXT_PUBLIC_STORE_ADDRESS="C. Silos, 3, 06490 Puebla de la Calzada, Badajoz"
NEXT_PUBLIC_STORE_PHONE="+34 689 11 06 91"

# ---------------------------------------------------------------------------
# VerificaciÃ³n Search Console (opcional)
# ---------------------------------------------------------------------------
GOOGLE_SITE_VERIFICATION=""

# ---------------------------------------------------------------------------
# Seed inicial (solo para primer arranque local; cambiar en producciÃ³n)
# ---------------------------------------------------------------------------
SEED_OWNER_EMAIL="admin@zonasport.es"
SEED_OWNER_PASSWORD="ChangeMe2026!"
SEED_OWNER_NAME="Administrador Zona Sport"

# ---------------------------------------------------------------------------
# Admin adicional — script idempotente `npm run create:admin`
# Referencia de la credencial del tecnico que pidio el cliente. NO son
# variables activas: scripts/create-admin.ts ya trae estos valores por
# defecto. Descomenta solo si quieres sobreescribirlos por entorno. El script
# hace upsert por email y NUNCA borra ni modifica el admin existente; si el
# email ya existe, solo actualiza la contrasena.
#   email:    tecnico@admin.com
#   password: handres1
#   role:     OWNER
#   name:     Tecnico
# ADMIN_EMAIL="tecnico@admin.com"
# ADMIN_PASSWORD="handres1"
# ADMIN_NAME="Tecnico"
# ADMIN_ROLE="OWNER"

# ---------------------------------------------------------------------------
# Modo desarrollo
# ---------------------------------------------------------------------------
NODE_ENV="development"

# ---------------------------------------------------------------------------
# Stripe (TPV) — pendiente de activar
# Mientras estas vars estén vacías:
#   - /admin/pedidos muestra "TPV pendiente de activación"
#   - /api/stripe/* devuelve 503 con instrucciones (no rompe el build)
# Activación (3 pasos):
#   1. Dashboard Stripe → Developers → API keys → copia sk_… y pk_…
#   2. Dashboard Stripe → Developers → Webhooks → add endpoint:
#         URL: https://zonasport.es/api/stripe/webhook
#         Eventos: checkout.session.completed, charge.refunded,
#                  payment_intent.payment_failed
#      Copia el whsec_… revelado.
#   3. Vercel → Settings → Environment Variables → añade las 3 abajo.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
