// ============================================================================
// Zona Sport â€” Prisma schema
// Modelo de datos del CRM unificado: productos (1 color = 1 producto), blog,
// leads, importaciones, redirecciones, ajustes y administradores.
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum ProductSource {
  LOCAL
  MIRAVIA
  AMAZON
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
  SPAM
}

enum AdminRole {
  OWNER
  EDITOR
}

enum Gender {
  HOMBRE
  MUJER
  UNISEX
  NINO
  NINA
  BEBE
  NO_ESPECIFICADO
}

enum ImportSource {
  XLSX
  MIRAVIA
  AMAZON
  WOOCOMMERCE
}

enum ImportStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ----------------------------------------------------------------------------
// Producto (1 color = 1 producto independiente)
// ----------------------------------------------------------------------------

model Product {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  shortName    String?
  description  String?       @db.Text

  brandId      String
  brand        Brand         @relation(fields: [brandId], references: [id])

  categoryId   String
  category     Category      @relation("LegacyCategory", fields: [categoryId], references: [id])

  // Bloque 2 (expand): relación m2m con categorías + categoría principal para
  // breadcrumbs/canonical. `categoryId` se MANTIENE intacto durante la fase
  // expand; se retira en la migración contractiva.
  primaryCategoryId String?
  primaryCategory   Category?     @relation("PrimaryCategory", fields: [primaryCategoryId], references: [id])
  categories        ProductCategory[]

  source       ProductSource @default(LOCAL)
  externalId   String?       // "pricat:030501", ASIN, ID Miravia
  externalUrl  String?       // URL afiliado Amazon o URL ficha proveedor
  modelCode    String?       // "M24205"
  sku          String?       @unique // SKU/Referencia interna editable desde /admin
  colorName    String        @default("Único")
  colorHex     String?

  gender       Gender        @default(NO_ESPECIFICADO)
  sportUse     String?       // "Montañismo/Trekking/Escalada"
  composition  String?       // "Poliéster 100%"

  costPrice    Decimal?      @db.Decimal(10, 2)
  retailPrice  Decimal       @db.Decimal(10, 2)
  salePrice    Decimal?      @db.Decimal(10, 2)
  taxRate      Decimal       @default(21) @db.Decimal(5, 2)

  mainImageUrl String?
  images       ProductImage[]
  sizes        ProductSize[]

  tags         String[]      @default([])
  status       ProductStatus @default(DRAFT)
  stock        Int           @default(0)
  weight       Decimal?      @db.Decimal(8, 3)
  isFeatured   Boolean       @default(false)
  isCustomized Boolean       @default(false) // si true, no sobrescribir desde feed

  metaTitle       String?
  metaDescription String?

  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  audits       ProductAudit[]

  @@unique([source, externalId])
  @@index([brandId, status])
  @@index([categoryId, status])
  @@index([primaryCategoryId])
  @@index([source])
  @@index([status, publishedAt])
  @@index([modelCode])
  @@index([isFeatured, status])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url         String                                // URL "large" en Vercel Blob
  urlThumb    String?                                // 400px
  urlMedium   String?                                // 800px
  alt         String                                // SEO obligatorio
  position    Int      @default(0)
  width       Int?
  height      Int?
  blurDataUrl String?                                // LQIP base64
  source      String?                                // "upload" | "url-external" | "amazon" | "miravia"
  originalUrl String?                                // URL de origen si vino de fuera
  createdAt   DateTime @default(now())

  @@index([productId, position])
}

model ProductSize {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size        String                                // "M", "L", "42", "8", "ÃšNICA"
  ean         String?                                // EAN-13 del SKU final
  stock       Int      @default(0)
  costPrice   Decimal? @db.Decimal(10, 2)
  retailPrice Decimal? @db.Decimal(10, 2)
  position    Int      @default(0)

  @@unique([productId, size])
  @@index([ean])
}

model ProductAudit {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  action    String   // "created", "updated", "published", "archived", "imported"
  changes   Json?    // diff key->{from,to}
  createdAt DateTime @default(now())

  @@index([productId, createdAt])
}

// ----------------------------------------------------------------------------
// Taxonomía
// ----------------------------------------------------------------------------

model Brand {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String    @unique
  logoUrl         String?
  description     String?   @db.Text
  metaTitle       String?
  metaDescription String?
  isFeatured      Boolean   @default(false)
  position        Int       @default(0)
  products        Product[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Category {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  parentId        String?
  parent          Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryTree")
  description     String?    @db.Text
  imageUrl        String?
  metaTitle       String?
  metaDescription String?
  position        Int        @default(0)
  isFeatured      Boolean    @default(false)
  products        Product[]          @relation("LegacyCategory")    // se mantiene en expand
  primaryFor      Product[]          @relation("PrimaryCategory")   // Bloque 2
  categoryLinks   ProductCategory[]  @relation("CategoryProducts")  // Bloque 2
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([parentId, position])
}

// Tabla pivote producto↔categoría (Bloque 2, m2m). Permite que un producto
// UNISEX aparezca en /hombre/<fam> y /mujer/<fam> a la vez. `primaryCategoryId`
// (en Product) marca la principal para breadcrumbs/canonical SEO.
model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation("CategoryProducts", fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

// ----------------------------------------------------------------------------
// Blog
// ----------------------------------------------------------------------------

model BlogPost {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  excerpt         String?    @db.Text
  contentMd       String     @db.Text
  coverImageUrl   String?
  author          String     @default("Equipo Zona Sport")
  tags            String[]   @default([])
  status          PostStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, publishedAt])
}

// ----------------------------------------------------------------------------
// Plantillas de descripción de producto
// Banco de copys genéricos que el admin aplica a productos nuevos con un
// click. `categorySlug` enlaza con `Category.slug`. Si no hay match
// específico, se usa la categoría `default` como fallback.
// ----------------------------------------------------------------------------

model DescriptionTemplate {
  id           String   @id @default(cuid())
  slug         String   @unique
  label        String
  categorySlug String
  body         String   @db.Text
  metaShort    String?  @db.Text
  position     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([categorySlug, isActive])
}

// ----------------------------------------------------------------------------
// CRM: leads y suscriptores
// ----------------------------------------------------------------------------

model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String
  phone       String?
  message     String     @db.Text
  sourcePage  String?
  productId   String?
  gdprConsent Boolean    @default(false)
  status      LeadStatus @default(NEW)
  notes       String?    @db.Text
  ipAddress   String?
  userAgent   String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  doiToken       String?
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  source         String?   // "footer", "popup", "checkout"
  createdAt      DateTime  @default(now())
}

// ----------------------------------------------------------------------------
// Admin users (Auth.js Credentials)
// ----------------------------------------------------------------------------

model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          AdminRole @default(EDITOR)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ----------------------------------------------------------------------------
// Imports
// ----------------------------------------------------------------------------

model ImportJob {
  id            String       @id @default(cuid())
  source        ImportSource
  status        ImportStatus @default(PENDING)
  mode          String?      // "create_update" | "create_only" | "update_only"
  fileUrl       String?
  fileName      String?
  totalRows     Int          @default(0)
  processedRows Int          @default(0)
  createdRows   Int          @default(0)
  updatedRows   Int          @default(0)
  errorRows     Int          @default(0)
  errors        Json?
  options       Json?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdBy     String?
  createdAt     DateTime     @default(now())

  @@index([status, createdAt])
}

// ----------------------------------------------------------------------------
// SEO ops
// ----------------------------------------------------------------------------

model RedirectRule {
  id        String   @id @default(cuid())
  from      String   @unique
  to        String
  type      Int      @default(301)
  hits      Int      @default(0)
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Settings (key/value JSON)
// ----------------------------------------------------------------------------

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Cart "intent" placeholder (fase 2: Stripe)
// Guarda intenciones de compra del visitante para conectar con carrito real
// cuando se integre Stripe. No es un carrito completo.
// ----------------------------------------------------------------------------

model CartIntent {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  items       Json     // [{ productId, size, qty }]
  email       String?
  whatsappRedirected Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
}

// ----------------------------------------------------------------------------
// Pedidos (Stripe TPV — Phase 2)
// Modelo de pedido que se rellena vía webhooks Stripe (checkout.session.completed)
// y se consume desde /admin/pedidos. Si las env vars STRIPE_SECRET_KEY y
// STRIPE_WEBHOOK_SECRET no están definidas, el sistema no recibe pedidos y la
// UI muestra "Pendiente de activación".
// ----------------------------------------------------------------------------

model Order {
  id                    String      @id @default(cuid())
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?     @unique
  stripeCustomerId      String?
  customerName          String?
  customerEmail         String?
  customerPhone         String?
  shippingAddress       Json?
  subtotal              Decimal     @db.Decimal(10, 2)
  shippingCost          Decimal     @default(0) @db.Decimal(10, 2)
  tax                   Decimal     @default(0) @db.Decimal(10, 2)
  total                 Decimal     @db.Decimal(10, 2)
  currency              String      @default("EUR")
  status                OrderStatus @default(PENDING)
  paymentStatus         String?
  deliveryMethod        String?     // "pickup" | "shipping"
  notes                 String?     @db.Text
  items                 OrderItem[]
  metadata              Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([status, createdAt])
  @@index([customerEmail])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  productSlug String?
  productName String
  productSku  String?
  variantSize String?
  unitPrice   Decimal  @db.Decimal(10, 2)
  quantity    Int
  subtotal    Decimal  @db.Decimal(10, 2)
  metadata    Json?

  @@index([orderId])
  @@index([productId])
}
