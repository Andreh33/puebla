// ============================================================================
// Zona Sport â€” Prisma schema
// Modelo de datos del CRM unificado: productos (1 color = 1 producto), blog,
// leads, importaciones, redirecciones, ajustes y administradores.
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum ProductSource {
  LOCAL
  MIRAVIA
  AMAZON
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
  SPAM
}

enum AdminRole {
  OWNER
  EDITOR
}

enum Gender {
  HOMBRE
  MUJER
  UNISEX
  NINO
  NINA
  BEBE
  NO_ESPECIFICADO
}

enum ImportSource {
  XLSX
  MIRAVIA
  AMAZON
  WOOCOMMERCE
}

enum ImportStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ----------------------------------------------------------------------------
// Producto (1 color = 1 producto independiente)
// ----------------------------------------------------------------------------

model Product {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  shortName    String?
  description  String?       @db.Text
  technicalDescription String? @db.Text   // Ficha técnica en texto libre (materiales, tecnología, cuidados)

  brandId      String
  brand        Brand         @relation(fields: [brandId], references: [id])

  categoryId   String
  category     Category      @relation("LegacyCategory", fields: [categoryId], references: [id])

  // Bloque 2 (expand): relación m2m con categorías + categoría principal para
  // breadcrumbs/canonical. `categoryId` se MANTIENE intacto durante la fase
  // expand; se retira en la migración contractiva.
  primaryCategoryId String?
  primaryCategory   Category?     @relation("PrimaryCategory", fields: [primaryCategoryId], references: [id])
  categories        ProductCategory[]

  source       ProductSource @default(LOCAL)
  externalId   String?       // "pricat:030501", ASIN, ID Miravia
  externalUrl  String?       // URL afiliado Amazon o URL ficha proveedor
  modelCode    String?       // "M24205"
  sku          String?       @unique // SKU/Referencia interna editable desde /admin
  colorName    String        @default("Único")
  colorHex     String?

  gender       Gender        @default(NO_ESPECIFICADO)
  sportUse     String?       // "Montañismo/Trekking/Escalada"
  // Bloque 3: tipo de calzado (solo familia calzado). Lista controlada por
  // FOOTWEAR_TYPES en lib/categories/footwear.ts (no enum Prisma — evita churn).
  footwearType String?       // running|trail|tenis|padel|casual|baloncesto|futbol|futbol_sala|chanclas
  // Bloque 6: tipo de prenda (solo familia textil). Lista controlada por
  // GARMENT_TYPES en lib/categories/garment.ts (no enum Prisma — evita churn).
  garmentType  String?       // camiseta|sudadera|chaqueta|abrigo|cortavientos|chandal|conjunto|pantalon|bermuda|mallas|banador|falda|calentador|vestido|chaleco
  // Bloque 6 §18 Fase 3.5: variante fina de la prenda (manga corta/larga,
  // pantalón corto/largo, mallas piratas, top, tirantes). Lista controlada
  // por GARMENT_VARIANTS en lib/categories/garment.ts.
  garmentVariant String?     // manga_corta|manga_larga|top|tirantes|pantalon_corto|pantalon_largo|mallas_cortas|mallas_largas|mallas_piratas
  composition  String?       // "Poliéster 100%"

  costPrice    Decimal?      @db.Decimal(10, 2)
  retailPrice  Decimal       @db.Decimal(10, 2)
  salePrice    Decimal?      @db.Decimal(10, 2)
  taxRate      Decimal       @default(21) @db.Decimal(5, 2)

  mainImageUrl String?
  images       ProductImage[]
  sizes        ProductSize[]

  tags         String[]      @default([])
  status       ProductStatus @default(DRAFT)
  stock        Int           @default(0)
  weight       Decimal?      @db.Decimal(8, 3)
  isFeatured   Boolean       @default(false)
  isOutlet     Boolean       @default(false) // si true, aparece ADEMÁS en /outlet (no se quita de su categoría)
  isCustomized Boolean       @default(false) // si true, no sobrescribir desde feed

  metaTitle       String?
  metaDescription String?

  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  audits       ProductAudit[]

  @@unique([source, externalId])
  @@index([brandId, status])
  @@index([categoryId, status])
  @@index([primaryCategoryId])
  @@index([footwearType])
  @@index([garmentType])
  @@index([garmentVariant])
  @@index([source])
  @@index([status, publishedAt])
  @@index([modelCode])
  @@index([isFeatured, status])
  @@index([isOutlet, status])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url         String                                // URL "large" en Vercel Blob
  urlThumb    String?                                // 400px
  urlMedium   String?                                // 800px
  alt         String                                // SEO obligatorio
  position    Int      @default(0)
  width       Int?
  height      Int?
  blurDataUrl String?                                // LQIP base64
  source      String?                                // "upload" | "url-external" | "amazon" | "miravia"
  originalUrl String?                                // URL de origen si vino de fuera
  createdAt   DateTime @default(now())

  @@index([productId, position])
}

model ProductSize {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size        String                                // "M", "L", "42", "8", "ÃšNICA"
  ean         String?                                // EAN-13 del SKU final
  stock       Int      @default(0)
  costPrice   Decimal? @db.Decimal(10, 2)
  retailPrice Decimal? @db.Decimal(10, 2)
  position    Int      @default(0)

  @@unique([productId, size])
  @@index([ean])
}

model ProductAudit {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  action    String   // "created", "updated", "published", "archived", "imported"
  changes   Json?    // diff key->{from,to}
  createdAt DateTime @default(now())

  @@index([productId, createdAt])
}

// ----------------------------------------------------------------------------
// Taxonomía
// ----------------------------------------------------------------------------

model Brand {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String    @unique
  logoUrl         String?
  description     String?   @db.Text
  metaTitle       String?
  metaDescription String?
  isFeatured      Boolean   @default(false)
  position        Int       @default(0)
  products        Product[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Category {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  parentId        String?
  parent          Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryTree")
  description     String?    @db.Text
  imageUrl        String?
  metaTitle       String?
  metaDescription String?
  position        Int        @default(0)
  isFeatured      Boolean    @default(false)
  products        Product[]          @relation("LegacyCategory")    // se mantiene en expand
  primaryFor      Product[]          @relation("PrimaryCategory")   // Bloque 2
  categoryLinks   ProductCategory[]  @relation("CategoryProducts")  // Bloque 2
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([parentId, position])
}

// Tabla pivote producto↔categoría (Bloque 2, m2m). Permite que un producto
// UNISEX aparezca en /hombre/<fam> y /mujer/<fam> a la vez. `primaryCategoryId`
// (en Product) marca la principal para breadcrumbs/canonical SEO.
model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation("CategoryProducts", fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

// ----------------------------------------------------------------------------
// Blog
// ----------------------------------------------------------------------------

model BlogPost {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  excerpt         String?    @db.Text
  contentMd       String     @db.Text
  coverImageUrl   String?
  author          String     @default("Equipo Zona Sport")
  tags            String[]   @default([])
  status          PostStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, publishedAt])
}

// ----------------------------------------------------------------------------
// Plantillas de descripción de producto
// Banco de copys genéricos que el admin aplica a productos nuevos con un
// click. `categorySlug` enlaza con `Category.slug`. Si no hay match
// específico, se usa la categoría `default` como fallback.
// ----------------------------------------------------------------------------

model DescriptionTemplate {
  id           String   @id @default(cuid())
  slug         String   @unique
  label        String
  categorySlug String
  body         String   @db.Text
  metaShort    String?  @db.Text
  position     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([categorySlug, isActive])
}

// ----------------------------------------------------------------------------
// CRM: leads y suscriptores
// ----------------------------------------------------------------------------

model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String
  phone       String?
  message     String     @db.Text
  sourcePage  String?
  productId   String?
  gdprConsent Boolean    @default(false)
  status      LeadStatus @default(NEW)
  notes       String?    @db.Text
  ipAddress   String?
  userAgent   String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  doiToken       String?
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  source         String?   // "footer", "popup", "checkout"
  createdAt      DateTime  @default(now())
}

// ----------------------------------------------------------------------------
// Admin users (Auth.js Credentials)
// ----------------------------------------------------------------------------

model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          AdminRole @default(EDITOR)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ----------------------------------------------------------------------------
// Imports
// ----------------------------------------------------------------------------

model ImportJob {
  id            String       @id @default(cuid())
  source        ImportSource
  status        ImportStatus @default(PENDING)
  mode          String?      // "create_update" | "create_only" | "update_only"
  fileUrl       String?
  fileName      String?
  totalRows     Int          @default(0)
  processedRows Int          @default(0)
  createdRows   Int          @default(0)
  updatedRows   Int          @default(0)
  errorRows     Int          @default(0)
  errors        Json?
  options       Json?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdBy     String?
  createdAt     DateTime     @default(now())

  @@index([status, createdAt])
}

// ----------------------------------------------------------------------------
// SEO ops
// ----------------------------------------------------------------------------

model RedirectRule {
  id        String   @id @default(cuid())
  from      String   @unique
  to        String
  type      Int      @default(301)
  hits      Int      @default(0)
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Settings (key/value JSON)
// ----------------------------------------------------------------------------

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Cart "intent" placeholder (fase 2: Stripe)
// Guarda intenciones de compra del visitante para conectar con carrito real
// cuando se integre Stripe. No es un carrito completo.
// ----------------------------------------------------------------------------

model CartIntent {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  items       Json     // [{ productId, size, qty }]
  email       String?
  whatsappRedirected Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
}

// ----------------------------------------------------------------------------
// Pedidos (Stripe TPV — Phase 2)
// Modelo de pedido que se rellena vía webhooks Stripe (checkout.session.completed)
// y se consume desde /admin/pedidos. Si las env vars STRIPE_SECRET_KEY y
// STRIPE_WEBHOOK_SECRET no están definidas, el sistema no recibe pedidos y la
// UI muestra "Pendiente de activación".
// ----------------------------------------------------------------------------

model Order {
  id                    String      @id @default(cuid())
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?     @unique
  stripeCustomerId      String?
  customerName          String?
  customerEmail         String?
  customerPhone         String?
  shippingAddress       Json?
  subtotal              Decimal     @db.Decimal(10, 2)
  shippingCost          Decimal     @default(0) @db.Decimal(10, 2)
  tax                   Decimal     @default(0) @db.Decimal(10, 2)
  total                 Decimal     @db.Decimal(10, 2)
  currency              String      @default("EUR")
  status                OrderStatus @default(PENDING)
  paymentStatus         String?
  deliveryMethod        String?     // "pickup" | "shipping"
  notes                 String?     @db.Text
  items                 OrderItem[]
  metadata              Json?
  // Facturación fiscal (Holded/VeriFactu): se rellenan al emitir la factura del
  // pedido en Holded (pedidos online + facturas a petición). Las ventas de TPV
  // NO se facturan por aquí (Modelo B). holdedDocId actúa de guarda idempotente.
  holdedDocId           String?
  holdedInvoiceNumber   String?
  invoicedAt            DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([status, createdAt])
  @@index([customerEmail])
}

// ----------------------------------------------------------------------------
// Clientes (libreta del TPV) — entidad reutilizable para el punto de venta.
// Se rellena al pulsar "Guardar cliente" en la caja y, best-effort, en cada
// venta presencial con nombre/teléfono. Los pedidos siguen guardando su
// customerName/customerPhone denormalizado; no hay FK (la deduplicación se
// hace por teléfono o, en su defecto, por nombre).
// ----------------------------------------------------------------------------
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([phone])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  productSlug String?
  productName String
  productSku  String?
  variantSize String?
  unitPrice   Decimal  @db.Decimal(10, 2)
  // Coste unitario CONGELADO en el momento de la venta (margen histórico).
  // Nullable y aditivo → se aplica solo con `prisma db push` en build. Se rellena
  // desde ProductSize.costPrice (si hay talla) o Product.costPrice.
  unitCost    Decimal? @db.Decimal(10, 2)
  quantity    Int
  subtotal    Decimal  @db.Decimal(10, 2)
  metadata    Json?

  @@index([orderId])
  @@index([productId])
}

// ----------------------------------------------------------------------------
// Analítica propia: contador de visitas agregado por (ruta, día). Lo alimenta
// POST /api/track desde el cliente, SOLO con consentimiento de cookies
// "analytics". 1 fila por (path, day) → la tabla no crece sin control.
// ----------------------------------------------------------------------------
model PageView {
  id        String   @id @default(cuid())
  path      String
  day       DateTime @db.Date
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([path, day])
  @@index([day])
}

// ----------------------------------------------------------------------------
// Facturas de proveedores (cuentas por pagar). Entrada 100% manual y libre:
// proveedor, nº de factura, marca y concepto son texto libre (sin relación con
// el catálogo). Cada factura tiene 1..N vencimientos, cada uno con su importe y
// su propio estado de pago (pagos fraccionados 30/60/90…). Aditivo: tablas
// nuevas, no toca nada existente.
// Reversible con: DROP TABLE "SupplierInvoiceDueDate"; DROP TABLE "SupplierInvoice";
// ----------------------------------------------------------------------------
model SupplierInvoice {
  id            String   @id @default(cuid())
  supplier      String                  // Proveedor (texto libre)
  brandLabel    String?                 // Marca/etiqueta libre (para filtrar)
  invoiceNumber String?                 // Nº de factura del proveedor
  concept       String?                 // Concepto / productos (texto libre)
  issueDate     DateTime @db.Date       // Fecha de la factura
  notes         String?                 // Notas largas opcionales
  // Valores de las columnas personalizadas (texto libre): { [columnId]: string }.
  customValues  Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dueDates      SupplierInvoiceDueDate[]

  @@index([supplier])
  @@index([issueDate])
}

model SupplierInvoiceDueDate {
  id        String          @id @default(cuid())
  invoiceId String
  invoice   SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  dueDate   DateTime        @db.Date           // Fecha de vencimiento del pago
  amount    Decimal         @db.Decimal(10, 2) // Importe de este vencimiento
  paid      Boolean         @default(false)    // Pagado o pendiente
  paidAt    DateTime?                          // Cuándo se marcó pagado
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([invoiceId])
  @@index([paid, dueDate])
}

// Columnas personalizadas ("a tu gusto") de la hoja de facturas. Globales:
// las mismas para todas las facturas (como en Excel). El valor de cada columna
// por factura vive en SupplierInvoice.customValues (JSON), no aquí.
model InvoiceColumn {
  id        String   @id @default(cuid())
  name      String
  position  Int      @default(0)
  width     Int      @default(160) // ancho en px (lo ajusta el usuario)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
}

// Registro de proveedores (lista guardada para el desplegable de la hoja de
// facturas). El nombre es único (case-insensitive a nivel de app). Las facturas
// siguen guardando el proveedor como texto denormalizado; renombrar aquí
// propaga el cambio a SupplierInvoice.supplier. Aditivo: tabla nueva.
model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}
