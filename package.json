{
  "name": "zonasport",
  "version": "0.1.0",
  "private": true,
  "description": "Zona Sport — Tienda deportiva multimarca en Puebla de la Calzada (Badajoz). Next.js 16 + React 19 + Tailwind 4 + Prisma 6.",
  "engines": {
    "node": ">=20.18.0"
  },
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "next dev --turbo --port 3000",
    "build": "prisma generate && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "seed": "tsx --env-file=.env.local prisma/seed.ts",
    "create:admin": "tsx --env-file=.env.local scripts/create-admin.ts",
    "import:pricat": "tsx --env-file=.env.local scripts/import-pricat.ts",
    "setup:db": "tsx --env-file=.env.local scripts/setup-db.ts",
    "audit:visual": "tsx --env-file=.env.local scripts/visual-audit.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-table": "^8.21.0",
    "@types/papaparse": "^5.5.2",
    "@types/three": "^0.184.1",
    "@uiw/react-md-editor": "^4.0.5",
    "@vercel/analytics": "^1.4.1",
    "@vercel/blob": "^0.27.3",
    "@vercel/speed-insights": "^1.1.0",
    "bcryptjs": "^2.4.3",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.4.3",
    "exceljs": "^4.4.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.471.0",
    "next": "^15.1.3",
    "next-auth": "5.0.0-beta.25",
    "paapi5-nodejs-sdk": "^1.0.0",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^9.0.3",
    "recharts": "^2.15.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "resend": "^4.0.1",
    "sharp": "^0.33.5",
    "shiki": "^1.26.1",
    "slugify": "^1.6.6",
    "sonner": "^1.7.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^2.6.0",
    "three": "^0.184.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0-beta.7",
    "@tailwindcss/typography": "^0.5.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "happy-dom": "^16.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.0.0-beta.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
